{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ChatDb": "Host=localhost;Port=5433;Database=andje_chat;Username=andje;Password=andje_dev_local"
  },
  "Database": {
    "AutoMigrate": true
  },
  "Diagnostics": {
    "Enabled": false,
    "IncludeCounts": true
  },
