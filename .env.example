# Copiar a .env si se quiere sobreescribir la configuración local.
# NUNCA subir el archivo .env al repositorio.

# Contraseña de PostgreSQL local. Si no se define, docker-compose usa
# el valor de desarrollo "andje_dev_local" (solo válido en la máquina local).
ANDJE_DB_PASSWORD=

# Puerto del host donde se publica el PostgreSQL del proyecto (por defecto
# 5433 para no chocar con instalaciones locales de PostgreSQL en 5432).
ANDJE_DB_PORT=
